# Required Telegram bot token from BotFather
TELEGRAM_BOT_TOKEN=

# Required MongoDB connection string used for alerted token deduplication and scanner state
MONGODB_URI=

# Optional owner Telegram user ID. Defaults safely to 580632670.
ADMIN_TELEGRAM_ID=580632670

# Optional scan interval in milliseconds. Defaults safely to 60000.
SCAN_INTERVAL_MS=60000
